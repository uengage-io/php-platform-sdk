{
  "name": "uengage.io/php-platform-sdk",
  "description": "PHP SDK for the uEngage platform API (zones, business, audit, auth). OAuth2 client_credentials, legacy session exchange, and static-Bearer auth modes with pluggable token caching (APCu / file / in-memory).",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "uengage",
    "platform",
    "sdk",
    "zones",
    "business",
    "audit",
    "auth",
    "postgis",
    "spatial"
  ],
  "require": {
    "php": ">=7.1",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^7.5 || ^9.6",
    "yoast/phpunit-polyfills": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "Uengage\\PlatformSdk\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Uengage\\PlatformSdk\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "config": {
    "sort-packages": true
  }
}
